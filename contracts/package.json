{
  "name": "zktrader-contracts",
  "version": "1.0.0",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:local": "hardhat test --network localfhevm",
    "deploy:local": "hardhat run scripts/deploy.ts --network localfhevm",
    "deploy:devnet": "hardhat run scripts/deploy.ts --network zamaDevnet",
    "fhevm:start": "npx fhevm-hardhat-plugin localfhevm:start",
    "fhevm:stop": "npx fhevm-hardhat-plugin localfhevm:stop",
    "fhevm:restart": "npm run fhevm:stop && npm run fhevm:start"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "dotenv": "^16.4.5",
    "fhevm": "^0.5.0",
    "fhevm-hardhat-plugin": "^0.5.0",
    "fhevmjs": "^0.5.0",
    "hardhat": "^2.20.1",
    "typescript": "^5.4.2"
  }
}
